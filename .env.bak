# ==========================================
#  Neo4j Configuration
# ==========================================
# 对应 docker-compose.dev.yml 中的端口和认证信息
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=StrongPassword123!
NEO4J_DATABASE=neo4j

# ==========================================
#  LLM (Ollama) Configuration
# ==========================================
# Windows 下 Ollama 默认监听 11434
# 确保系统环境变量 OLLAMA_HOST 已设置为 0.0.0.0 (见 README)
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=qwen2.5:7b

# 提取参数配置
EXTRACTION_CHUNK_SIZE=2000
EXTRACTION_TEMPERATURE=0.1

# ==========================================
#  Application Configuration
# ==========================================
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# 数据文件路径 (相对于项目根目录)
DATA_DIR=data
RAW_TXT_FILE=三国演义.txt
EXTRACTED_JSON_FILE=extracted_relations.json
CLEANED_JSON_FILE=cleaned_kg.json